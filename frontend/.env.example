# Local development (optional)
# If not set, the app falls back to:
# - dev: http://localhost:3000 (/api on same host)
# - prod: same-origin (/api and socket on same domain)

# Backend API base (must include /api)
VITE_API_URL=http://localhost:3000/api

# Socket.IO server origin (no /api)
VITE_SOCKET_URL=http://localhost:3000

